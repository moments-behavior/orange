namespace FetchGame;

enum ServerControl : byte {
    IDEL = 0,
    START = 1,
    SETPTP = 2,
    STOP = 3,
    QUIT = 4
}

table bring_up_message {
    server_name:string;
    num_cameras:short;
}

table Server {
    control:ServerControl = IDEL;
    server_mesg:bring_up_message;
    ptp_global_time:ulong;
}

root_type Server;