namespace FetchGame;

enum ServerControl : byte {
    IDEL = 0,
    START = 1,
    SETPTP = 2,
    STOP = 3,
    QUIT = 4
}

struct Vec3 {
  x:float;
  y:float;
  z:float;
}

table Ramp {
    position:Vec3;
    orientation:float;
}

table Server {
    control:ServerControl = IDEL;
    ptp_global_time:ulong;
}

table Scene {
    ramp:Ramp;
    server:Server;
}

root_type Scene;