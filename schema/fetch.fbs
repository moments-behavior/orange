namespace FetchGame;

enum ServerControl : byte {
    IDLE,
    OPENCAMERA,
    STARTTHREAD,
    STARTRECORDING,
    STOPRECORDING,
    STARTCALIB,
    CALIBOPENCAMERA,
    QUIT
}

enum SignalType: byte {
    ClientBringup,
    ClientStateUpdate,
    INDIGO,
    INDIGO_TRIAL_TRIGGER,
    CalibrationNextPose,
    CalibrationPoseReached,
    CalibrationDone
}

enum ManagerState: byte {
    IDLE,
    CONNECTED,
    CAMERAOPENED,
    ERROR,
    THREADREADY,
    RECORDSTOPPED,
    RECORDINGSTARTED,
    CALIBFOLDER,
    CALIBCAMERAOPENED
}

table bring_up_message {
    server_name:string;
    num_cameras:short;
}

table Server {
    signal_type:SignalType = ClientBringup;
    control:ServerControl = IDLE;
    server_mesg:bring_up_message;
    config_folder:string;
    record_folder:string;
    calib_folder:string;
    encoder_setup:string;
    ptp_global_time:ulong;
    server_state:ManagerState = IDLE;
}

root_type Server;
